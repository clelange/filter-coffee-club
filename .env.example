# The URL reachable by phones scanning the kiosk QR code.
FCC_PUBLIC_BASE_URL=http://filter-coffee-club.local

# Pin production deployments to a release such as v2026.07.0. Use latest only
# for local evaluation; it is a moving tag and is not suitable for rollbacks.
FCC_IMAGE=ghcr.io/clelange/filter-coffee-club
FCC_IMAGE_TAG=latest

# Set true when Traefik exposes the app exclusively over HTTPS.
FCC_COOKIE_SECURE=false

# Optional comma-separated trusted origins when requests pass through another origin.
FCC_ALLOWED_ORIGINS=

# Populate fictional sample data and enable public-demo abuse protections.
FCC_DEMO_MODE=false
